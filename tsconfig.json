{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "lib": ["es2022", "dom"],
    "target": "es2015",
    "paths": {
      "*": ["./src-js/*"]
    },
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["@types/emscripten", "@types/mocha"]
  },
  "include": ["./src-js/*/src/**/*", "./src-js/*/tests/**/*"],
  "exclude": ["**/node_modules/**/*", "**/webpack*"],
  "$schema": "https://www.schemastore.org/tsconfig"
}
